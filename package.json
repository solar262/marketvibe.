{
  "name": "marketvibe-portal",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch server.ts",
    "dev:web": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "start": "tsx server.ts",
    "test": "vitest run",
    "cron:proofpacks": "tsx crons/build-proof-packs.ts",
    "cron:daily-radar": "tsx crons/daily-radar.ts"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.4",
    "@vitejs/plugin-react": "^4.3.4",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^17.5.0",
    "vite": "^6.0.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "concurrently": "^9.1.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "optionalDependencies": {
    "mjml": "^5.4.0",
    "puppeteer": "^24.43.1"
  }
}
