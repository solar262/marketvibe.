{
    "cleanUrls": true,
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/$1"
        },
        {
            "src": "/ads.txt",
            "dest": "/ads.txt"
        },
        {
            "src": "/robots.txt",
            "dest": "/robots.txt"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}